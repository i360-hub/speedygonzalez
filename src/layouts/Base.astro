---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CallBar from '../components/CallBar.astro';
import Analytics from '../components/Analytics.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { businessSchema } from '../data/business';
import { breadcrumbSchema } from '../data/schema';

export interface Props {
  title: string;
  description: string;
  path: string;
  ogImage?: string;
  preloadImage?: string;
  preloadImageset?: { srcset: string; sizes: string };
  noindex?: boolean;
  schema?: Record<string, unknown>[];
  publishedTime?: string;
  modifiedTime?: string;
  /** Deep pages pass a trail; it renders crumbs AND emits BreadcrumbList. */
  breadcrumbs?: { href: string; label: string }[];
  /**
   * Emit AggregateRating in the business node. Only set this on pages that
   * render real review text — Google requires the rating to be visible on the
   * page carrying the markup. validate-schema.js fails the build otherwise.
   */
  showRating?: boolean;
}

const { breadcrumbs, schema = [], showRating = false, ...head } = Astro.props;

const allSchema = [
  businessSchema(showRating),
  ...(breadcrumbs?.length ? [breadcrumbSchema(breadcrumbs)] : []),
  ...schema,
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...head} schema={allSchema} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    {breadcrumbs?.length ? <Breadcrumbs trail={breadcrumbs} /> : null}
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CallBar />
    <Analytics />
  </body>
</html>
