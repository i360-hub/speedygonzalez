---
import '../styles/global.css';
import { SITE_URL } from '../data/business';
import { srcset, fallback, HERO_SIZES } from '../data/images';

export interface Props {
  title: string;
  description: string;
  /** Absolute-from-root path, e.g. "/services/metal-roofing" */
  path: string;
  /** Extension-less hero base path; .jpg is appended for OG. */
  ogImage?: string;
  /** Extension-less base path of the LCP hero, if the page has one. */
  preloadImage?: string;
  noindex?: boolean;
  /** JSON-LD nodes rendered into <head>. */
  schema?: Record<string, unknown>[];
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  path,
  ogImage = '/og.jpg',
  preloadImage,
  noindex = false,
  schema = [],
  publishedTime,
  modifiedTime,
} = Astro.props;

const canonical = new URL(path === '/' ? '/' : path, SITE_URL).href;
// og.jpg is a ready-made 1200x630; hero base paths need the extension added.
const ogImageUrl = new URL(ogImage.endsWith('.jpg') ? ogImage : fallback(ogImage), SITE_URL).href;

if (title.length > 60) {
  throw new Error(`Title over 60 chars (${title.length}) on ${path}: "${title}"`);
}
if (description.length > 155) {
  throw new Error(`Meta description over 155 chars (${description.length}) on ${path}`);
}
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, follow" />}

<link
  rel="preload"
  href="/fonts/inter-latin-wght-normal.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>
{
  /* Preload the AVIF the <picture> will pick. Browsers without AVIF skip this
     on `type` and fetch WebP/JPEG from the markup instead. */
  preloadImage && (
    <link
      rel="preload"
      as="image"
      type="image/avif"
      imagesrcset={srcset(preloadImage, 'avif')}
      imagesizes={HERO_SIZES}
      fetchpriority="high"
    />
  )
}

<style is:inline>
  @font-face {
    font-family: 'Inter';
    font-style: normal;
    font-display: swap;
    font-weight: 100 900;
    src: url('/fonts/inter-latin-wght-normal.woff2') format('woff2-variations');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC,
      U+0304, U+0308, U+0329, U+2000-206F, U+2074, U+20AC, U+2122, U+2191, U+2193, U+2212,
      U+2215, U+FEFF, U+FFFD;
  }
</style>

<meta property="og:type" content={publishedTime ? 'article' : 'website'} />
<meta property="og:site_name" content="Speedy Gonzalez Roofing" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:locale" content="en_US" />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />

<meta name="theme-color" content="#14171a" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />

{
  schema.map((node) => (
    <script type="application/ld+json" set:html={JSON.stringify(node)} />
  ))
}
