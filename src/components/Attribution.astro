---
/**
 * Lead-source attribution for the GoHighLevel form.
 *
 * Problem it solves: the GHL form is a cross-origin iframe, so GHL can only see
 * the *parent page* as the referrer — it labels every lead "Direct traffic",
 * even the ones that came from Google. (Verified in the CRM: real organic leads
 * logged as Direct.)
 *
 * Fix: on the visitor's FIRST page this session, capture where they actually
 * came from (UTM tags, ad click ids, or the external referrer classified into
 * source/medium), persist it in a first-party cookie, then append it to the GHL
 * form iframe's URL as utm_* params. GHL reads those params off the iframe URL
 * and stamps them on the contact — so the CRM shows "google / organic" instead
 * of "Direct".
 *
 * First-touch is deliberate: someone who lands on the homepage from Google then
 * clicks through to /contact would otherwise attribute to the (same-site)
 * homepage referrer. We freeze the original source on first sight and reuse it.
 *
 * Runs site-wide (capture) but only rewrites an iframe when a GHL form is on the
 * page (i.e. /contact). The form's real src stays in the server HTML, so if this
 * script ever errors the form still loads — it just falls back to "Direct".
 *
 * Reusable across the agency's other rebuilds; only the cookie name is per-site.
 */
const COOKIE = 'sg_ft';
---

<script is:inline define:vars={{ COOKIE }}>
  (function () {
    var MAXAGE = 60 * 60 * 24 * 90; // 90 days — first-touch persists across visits

    function readCookie(name) {
      var m = document.cookie.match('(?:^|; )' + name + '=([^;]*)');
      return m ? decodeURIComponent(m[1]) : '';
    }
    function writeCookie(name, val) {
      document.cookie =
        name + '=' + encodeURIComponent(val) + ';path=/;max-age=' + MAXAGE + ';SameSite=Lax';
    }

    var host = location.hostname.replace(/^www\./, '');
    var SEARCH = /(google|bing|yahoo|duckduckgo|ecosia|brave|baidu|yandex|ask|aol)\./;
    var SOCIAL = /(facebook|instagram|t\.co|twitter|x\.com|lnkd\.in|linkedin|youtube|pinterest|reddit|tiktok|nextdoor)/;

    /** Classify THIS pageview into utm_source/medium (+ campaign/term/content). */
    function classify() {
      var p = new URLSearchParams(location.search);
      var o = {
        utm_source: p.get('utm_source') || '',
        utm_medium: p.get('utm_medium') || '',
        utm_campaign: p.get('utm_campaign') || '',
        utm_term: p.get('utm_term') || '',
        utm_content: p.get('utm_content') || '',
        gclid: p.get('gclid') || p.get('wbraid') || p.get('gbraid') || '',
        fbclid: p.get('fbclid') || '',
      };

      if (o.utm_source) return o; // explicit UTMs win

      if (o.gclid) {
        o.utm_source = 'google';
        o.utm_medium = o.utm_medium || 'cpc';
        return o;
      }
      if (o.fbclid) {
        o.utm_source = 'facebook';
        o.utm_medium = o.utm_medium || 'paid-social';
        return o;
      }

      var ref = document.referrer || '';
      var rhost = '';
      try {
        rhost = ref ? new URL(ref).hostname.replace(/^www\./, '') : '';
      } catch (e) {}

      if (!rhost || rhost === host) {
        o.utm_source = '(direct)';
        o.utm_medium = '(none)';
      } else if (SEARCH.test(rhost)) {
        o.utm_source = rhost.split('.')[0];
        o.utm_medium = 'organic';
      } else if (SOCIAL.test(rhost)) {
        o.utm_source = rhost === 't.co' ? 'twitter' : rhost.split('.')[0];
        o.utm_medium = 'social';
      } else {
        o.utm_source = rhost;
        o.utm_medium = 'referral';
      }
      return o;
    }

    // Freeze first-touch once; reuse it forever after.
    var ft;
    var stored = readCookie(COOKIE);
    if (stored) {
      try {
        ft = JSON.parse(stored);
      } catch (e) {}
    }
    if (!ft || !ft.utm_source) {
      ft = classify();
      writeCookie(COOKIE, JSON.stringify(ft));
    }

    // Append first-touch params to any GHL form iframe on this page.
    function inject() {
      var sel =
        'iframe[src*="leadconnectorhq.com/widget/form"],iframe[src*="link.msgsndr.com/widget/form"]';
      var frames = document.querySelectorAll(sel);
      for (var i = 0; i < frames.length; i++) {
        var f = frames[i];
        if (f.dataset.attr) continue;
        var src = f.getAttribute('src');
        if (!src) continue;
        var qs = [];
        Object.keys(ft).forEach(function (k) {
          if (ft[k]) qs.push(k + '=' + encodeURIComponent(ft[k]));
        });
        if (!qs.length) continue;
        f.dataset.attr = '1';
        f.setAttribute('src', src + (src.indexOf('?') === -1 ? '?' : '&') + qs.join('&'));
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', inject);
    } else {
      inject();
    }
  })();
</script>
