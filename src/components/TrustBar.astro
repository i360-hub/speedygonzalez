---
/**
 * Sitewide trust strip (supplement spec §1.3). Replaces the old topbar rather
 * than stacking under it — the topbar already claimed the license and free
 * inspections, and repeating them twice above the fold reads as filler.
 *
 * Every claim here is verified and traceable to src/data/business.ts:
 *   - 4.9 / 152 Google reviews — verified against GBP 2026-07-16
 *   - BBB A+ Rated — verified on bbb.org 2026-07-16 (NOT accredited: never
 *     render the torch/seal, and never say "accredited")
 *   - AR license RR0540931024
 *   - 20+ years, 500+ roofs
 * Do not add a claim to this bar that isn't backed in business.ts.
 */
import { business, rating, bbb, telHref } from '../data/business';
---

<div class="trust-bar">
  <div class="wrap inner">
    <ul class="claims">
      <li class="rating">
        <span class="stars" aria-hidden="true">&#9733;</span>
        <strong>{rating.value}</strong>
        <a href="/reviews">{rating.count} Google Reviews</a>
      </li>
      <li>
        <a href={bbb.profileUrl} rel="nofollow noopener" target="_blank">BBB A+ Rated</a>
      </li>
      <li>AR Licensed {business.licenses.roofing}</li>
      <li>20+ Years &middot; 500+ Roofs</li>
      <li><a href="/contact">Free Inspections</a></li>
    </ul>

    <p class="pine-bluff">
      Pine Bluff:
      <a href={telHref(business.phones.pineBluff)}>{business.phones.pineBluff}</a>
    </p>
  </div>
</div>

<style>
  .trust-bar {
    background: var(--charcoal-900);
    color: var(--charcoal-100);
    font-size: var(--step--1);
  }

  .inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.3rem var(--space-md);
    padding-block: 0.5rem;
  }

  .claims {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem var(--space-md);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .claims li {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    max-width: none;
    font-weight: 600;
    white-space: nowrap;
  }

  .claims li + li::before {
    content: '';
    width: 1px;
    height: 1em;
    background: var(--charcoal-700);
    margin-right: var(--space-md);
  }

  .trust-bar a {
    color: var(--white);
    text-decoration: none;
    border-bottom: 1px solid var(--charcoal-500);
  }

  .trust-bar a:hover {
    border-bottom-color: var(--orange-500);
  }

  .stars {
    color: var(--star);
  }

  .rating strong {
    color: var(--white);
  }

  .pine-bluff {
    margin: 0;
    max-width: none;
    white-space: nowrap;
  }

  .pine-bluff a {
    font-weight: 700;
  }

  /* The full strip wraps into a pile on phones. Keep the two claims that
     actually convert (rating, BBB) and the Pine Bluff number; drop the rest —
     they all appear again in the footer. */
  @media (max-width: 860px) {
    .claims li:nth-child(n + 3) {
      display: none;
    }
    .claims li + li::before {
      margin-right: 0.5rem;
    }
    .inner {
      justify-content: center;
    }
  }

  @media (max-width: 520px) {
    .pine-bluff {
      display: none;
    }
  }
</style>
