---
import { business, telHref, rating } from '../data/business';

export interface Props {
  heading?: string;
  body?: string;
}

const {
  heading = 'Ready for a free roof inspection?',
  body = 'Tell us what your roof is doing. We come out, look it over, and give you a written estimate at no cost.',
} = Astro.props;
---

<section class="cta-band">
  <div class="wrap inner">
    <div>
      <h2>{heading}</h2>
      <p>{body}</p>
      <p class="trust">
        <span class="stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span>{rating.value} stars &middot; {business.experience} in Hot Springs &middot; Free estimates</span>
      </p>
    </div>
    <div class="btn-row">
      <a href={telHref(business.phones.primary)} class="btn btn-primary">
        Call {business.phones.primary}
      </a>
      <a href="/contact" class="btn btn-ghost">Get a free estimate</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    background: var(--charcoal-800);
    color: var(--white);
    padding-block: var(--space-xl);
  }

  .inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  h2 {
    margin-top: 0;
    font-size: var(--step-2);
  }

  p {
    color: var(--charcoal-100);
  }

  p:last-child {
    margin-bottom: 0;
  }

  .trust {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    font-size: var(--step--1);
  }
</style>
