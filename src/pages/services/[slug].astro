---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Prose from '../../components/Prose.astro';
import Faq from '../../components/Faq.astro';
import CtaBand from '../../components/CtaBand.astro';
import ReviewStrip from '../../components/ReviewStrip.astro';
import SpeedyStandard from '../../components/SpeedyStandard.astro';
import InlinePhoto from '../../components/InlinePhoto.astro';
import { faqSchema, serviceSchema } from '../../data/schema';
import { slugToCity } from '../../data/areas';

/**
 * A real, verified inline photo per service (supplement §3.2), keyed by slug.
 * Only slugs with a genuinely relevant photo get one — no forcing a photo where
 * it does not fit. { name = manifest photo, caption }.
 */
const servicePhoto: Record<string, { name: string; caption: string }> = {
  'metal-roofing': {
    name: 'metal-roof-lakefront',
    caption: 'A standing seam metal roof we installed on a Hot Springs lakefront home.',
  },
  'shingle-roofing': {
    name: 'reroof-in-progress-tyvek',
    caption: 'A full shingle re-roof in progress on a Hot Springs home.',
  },
  'roof-repair': {
    name: 'roof-rebuild-crew',
    caption: 'Our crew rebuilding a roof structure on a Hot Springs home.',
  },
  'roof-leak-repair': {
    name: 'aged-shingle-inspection',
    caption: 'Worn, aging shingles like these are a common source of leaks.',
  },
  'storm-damage-repair': {
    name: 'storm-damaged-roof',
    caption: 'Storm-torn shingles and exposed decking on a central Arkansas home.',
  },
  'hail-damage-repair': {
    name: 'storm-damaged-wood-shakes',
    caption: 'A wood shake roof battered by an Arkansas hail storm.',
  },
  'tpo-flat-roofing': {
    name: 'metal-building-carport',
    caption: 'A steel building and carport we built in Garland County.',
  },
  gutters: {
    name: 'finished-metal-porch',
    caption: 'A finished Hot Springs home after exterior work by our crew.',
  },
  siding: {
    name: 'cedar-post-carport',
    caption: 'Custom exterior work: a cedar-post porch on a metal building.',
  },
};

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const path = `/services/${entry.id}`;
const { Content } = await render(entry);

const breadcrumbs = [
  { href: '/services', label: 'Services' },
  { href: path, label: d.title },
];

const schema = [
  serviceSchema({
    name: d.title,
    description: d.summary,
    path,
    areas: d.relatedAreas.map(slugToCity),
  }),
  faqSchema(d.faqs),
];
---

<Base
  title={d.metaTitle}
  description={d.metaDescription}
  path={path}
  preloadImage={d.heroImage}
  breadcrumbs={breadcrumbs}
  schema={schema}
>
  <Hero eyebrow="Hot Springs, Arkansas" h1={d.h1} summary={d.summary} image={d.heroImage} />

  <SpeedyStandard />

  <div class="wrap layout">
    <article>
      <Prose>
        <Content />
      </Prose>

      {
        servicePhoto[entry.id] && (
          <InlinePhoto
            name={servicePhoto[entry.id].name}
            caption={servicePhoto[entry.id].caption}
          />
        )
      }

      <Faq faqs={d.faqs} />
    </article>

    <aside aria-label="Service details">
      {
        d.priceRange && (
          <div class="card price">
            <h2>Typical cost</h2>
            <p class="price-value">{d.priceRange}</p>
            <p class="price-note">
              Every roof is different. We give you an exact price in writing after a free
              inspection — no guessing, no pressure.
            </p>
          </div>
        )
      }

      <div class="card">
        <h2>Where we do this work</h2>
        <ul class="area-links">
          {
            d.relatedAreas.map((slug) => (
              <li>
                <a href={`/service-areas/${slug}`}>{slugToCity(slug)}</a>
              </li>
            ))
          }
        </ul>
        <a href="/service-areas">See all service areas</a>
      </div>

      <div class="card">
        <h2>Other services</h2>
        <ul class="area-links">
          <li><a href="/services">All roofing services</a></li>
          <li><a href="/services/roof-repair">Roof repair</a></li>
          <li><a href="/services/storm-damage-repair">Storm damage repair</a></li>
          <li><a href="/insurance-claims">Insurance claim help</a></li>
        </ul>
      </div>
    </aside>
  </div>

  <ReviewStrip slug={entry.id} alt />

  <CtaBand />
</Base>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: var(--space-xl);
    align-items: start;
    padding-block: var(--space-xl);
  }

  @media (max-width: 900px) {
    /* minmax(0, 1fr), not 1fr: a bare 1fr floors the track at min-content, and a
       nowrap table then blows the track past the viewport into a horizontal scroll. */
    .layout {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  aside {
    position: sticky;
    top: 90px;
    display: grid;
    gap: var(--space-md);
  }

  @media (max-width: 900px) {
    aside {
      position: static;
    }
  }

  aside h2 {
    margin-top: 0;
    font-size: var(--step-0);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--charcoal-500);
  }

  .price-value {
    font-size: var(--step-2);
    font-weight: 800;
    color: var(--charcoal-900);
    margin-bottom: var(--space-xs);
    line-height: 1.25;
  }

  .price-note {
    font-size: var(--step--1);
    color: var(--text-muted);
    margin-bottom: 0;
  }

  .area-links {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-sm);
    display: grid;
    gap: 0.35rem;
  }
</style>
