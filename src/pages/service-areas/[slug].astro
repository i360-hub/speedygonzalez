---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Hero from '../../components/Hero.astro';
import Prose from '../../components/Prose.astro';
import Faq from '../../components/Faq.astro';
import CtaBand from '../../components/CtaBand.astro';
import ReviewStrip from '../../components/ReviewStrip.astro';
import { faqSchema, localAreaSchema } from '../../data/schema';
import { slugToService } from '../../data/areas';
import { business, telHref } from '../../data/business';

export async function getStaticPaths() {
  const areas = await getCollection('areas');
  return areas.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const path = `/service-areas/${entry.id}`;
const { Content } = await render(entry);

const breadcrumbs = [
  { href: '/service-areas', label: 'Service Areas' },
  { href: path, label: d.city },
];

const schema = [
  localAreaSchema({
    city: d.city,
    path,
    description: d.metaDescription,
    services: d.servicesOffered.map(slugToService),
  }),
  faqSchema(d.faqs),
];

/** Pine Bluff has its own local number (spec §1). */
const localPhone =
  entry.id === 'pine-bluff' ? business.phones.pineBluff : business.phones.primary;
---

<Base
  title={d.metaTitle}
  description={d.metaDescription}
  path={path}
  preloadImage={d.heroImage}
  breadcrumbs={breadcrumbs}
  schema={schema}
>
  <Hero
    eyebrow={`Roofing in ${d.city}, Arkansas`}
    h1={d.h1}
    summary={d.localIntro}
    image={d.heroImage}
  />

  <div class="wrap layout">
    <article>
      <Prose>
        <Content />
      </Prose>

      <Faq faqs={d.faqs} heading={`${d.city} roofing questions`} />
    </article>

    <aside aria-label={`${d.city} details`}>
      <div class="card">
        <h2>Call {d.city}</h2>
        <p class="phone">
          <a href={telHref(localPhone)}>{localPhone}</a>
        </p>
        <p class="note">Open {business.hours}. Free inspections and written estimates.</p>
        <a href="/contact" class="btn btn-primary full">Get a free estimate</a>
      </div>

      <div class="card">
        <h2>Services in {d.city}</h2>
        <ul class="links">
          {
            d.servicesOffered.map((slug) => (
              <li>
                <a href={`/services/${slug}`}>{slugToService(slug)}</a>
              </li>
            ))
          }
        </ul>
      </div>

      {
        d.landmarks?.length ? (
          <div class="card">
            <h2>Neighborhoods we cover</h2>
            <ul class="plain">
              {d.landmarks.map((l) => (
                <li>{l}</li>
              ))}
            </ul>
          </div>
        ) : null
      }

      <div class="card">
        <h2>Nearby areas</h2>
        <ul class="links">
          <li><a href="/service-areas">All service areas</a></li>
          <li><a href="/service-areas/hot-springs">Hot Springs</a></li>
          <li><a href="/reviews">Read local reviews</a></li>
        </ul>
      </div>
    </aside>
  </div>

  <ReviewStrip slug={entry.id} heading={`What ${d.city} customers said`} alt />

  <CtaBand heading={`Need a roofer in ${d.city}?`} />
</Base>

<style>
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: var(--space-xl);
    align-items: start;
    padding-block: var(--space-xl);
  }

  @media (max-width: 900px) {
    /* minmax(0, 1fr), not 1fr: a bare 1fr floors the track at min-content, and a
       nowrap table then blows the track past the viewport into a horizontal scroll. */
    .layout {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  aside {
    position: sticky;
    top: 90px;
    display: grid;
    gap: var(--space-md);
  }

  @media (max-width: 900px) {
    aside {
      position: static;
    }
  }

  aside h2 {
    margin-top: 0;
    font-size: var(--step-0);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--charcoal-500);
  }

  .phone {
    font-size: var(--step-2);
    font-weight: 800;
    margin-bottom: var(--space-xs);
  }

  .phone a {
    text-decoration: none;
  }

  .note {
    font-size: var(--step--1);
    color: var(--text-muted);
  }

  .full {
    width: 100%;
  }

  .links,
  .plain {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.35rem;
  }

  .plain li {
    color: var(--charcoal-700);
    font-size: var(--step--1);
  }
</style>
