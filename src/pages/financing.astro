---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import CtaBand from '../components/CtaBand.astro';
import Faq from '../components/Faq.astro';
import { faqSchema } from '../data/schema';
import { business, telHref } from '../data/business';

const faqs = [
  {
    q: 'Do you offer financing for a new roof?',
    a: 'Yes. We offer financing so you do not have to pay for the whole roof up front. Ask us about it at your free estimate and we will walk you through what is available for your job.',
  },
  {
    q: 'Can I get a roof if my insurance only covers part of it?',
    a: 'Often yes. Insurance may cover storm damage but leave you the deductible. Financing can cover the gap. Bring us your claim paperwork and we will look at it with you.',
  },
  {
    q: 'Does it cost anything to ask about financing?',
    a: 'No. Asking costs nothing, and so does the inspection and estimate. You are not committed to anything by having the conversation.',
  },
  {
    q: 'What if I would rather just pay for it?',
    a: 'That is fine. Plenty of homeowners do. Financing is an option, not something we push. You get the same roof and the same price either way.',
  },
];
---

<Base
  title="Roof Financing in Hot Springs, AR | Speedy Gonzalez"
  description="Roof financing for Hot Springs homeowners. Spread the cost of a new roof or a storm repair. Free estimate first. Call 501-359-5550."
  path="/financing"
  preloadImage="/images/metal-roof-home"
  breadcrumbs={[{ href: '/financing', label: 'Financing' }]}
  schema={[faqSchema(faqs)]}
>
  <Hero
    eyebrow="Financing"
    h1="Roof Financing in Hot Springs, Arkansas"
    summary="A roof never breaks at a good time. We offer financing so you can fix it now and pay for it over time. Ask us at your free estimate — there is no cost to find out."
    image="/images/metal-roof-home"
  />

  <section class="section">
    <div class="wrap narrow">
      <h2>Why would I finance a roof?</h2>
      <p>
        Because a bad roof gets worse and more expensive every month you wait. A small leak
        you fix today can rot decking, soak insulation, and grow mold if you leave it.
      </p>
      <p>
        Financing lets you stop the damage now instead of waiting for a better month. Here is
        what waiting usually costs.
      </p>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>If you wait</th>
              <th>What happens</th>
              <th>What it adds</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>A few weeks</td>
              <td>Water stains the ceiling</td>
              <td>Drywall and paint</td>
            </tr>
            <tr>
              <td>A few months</td>
              <td>Decking gets soft, insulation soaks</td>
              <td>New decking and insulation</td>
            </tr>
            <tr>
              <td>A year or more</td>
              <td>Rot spreads to framing, mold sets in</td>
              <td>Framing repair and mold work</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2>How does financing work here?</h2>
      <p>
        First we come out and inspect your roof for free. Then you get a written price. If you
        want to spread that price out, we walk you through the financing options for your job.
      </p>
      <p>
        You are not signing anything by asking. The inspection and the estimate are free
        whether you finance or not.
      </p>

      <h2>What can I finance?</h2>
      <p>
        Most of what we do. A full roof replacement is the usual reason people ask, but it is
        not the only one.
      </p>
      <ul>
        <li><a href="/services/shingle-roofing">Shingle roof replacement</a></li>
        <li><a href="/services/metal-roofing">Metal roof installation</a></li>
        <li><a href="/services/tpo-flat-roofing">TPO and flat roofing</a></li>
        <li><a href="/services/storm-damage-repair">Storm damage repair</a> and insurance deductibles</li>
        <li><a href="/services/gutters">Gutters</a> and <a href="/services/siding">siding</a></li>
      </ul>

      <h2>What does a roof cost around here?</h2>
      <p>
        It depends on your roof. Size, pitch, shape, and what sits under the old roof all move
        the number, so we do not quote over the phone. The inspection is free, and the price
        comes to you in writing.
      </p>
      <p>
        Read more about <a href="/blog/roof-replacement-cost-arkansas">what a new roof costs in
        Hot Springs</a>, or just <a href="/contact">get a free estimate</a> and find out for
        certain.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="wrap">
      <Faq faqs={faqs} heading="Financing questions" />
    </div>
  </section>

  <section class="section">
    <div class="wrap ask">
      <div>
        <h2>Ask about financing</h2>
        <p>
          Call {business.phones.primary} or book a free estimate. Tell us what is going on with
          your roof and we will take it from there.
        </p>
      </div>
      <div class="btn-row">
        <a href={telHref(business.phones.primary)} class="btn btn-primary">
          Call {business.phones.primary}
        </a>
        <a href="/contact" class="btn btn-outline">Get a free estimate</a>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .narrow {
    max-width: var(--measure);
  }

  .ask {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }

  .ask h2 {
    margin-top: 0;
  }

  .ask p {
    margin-bottom: 0;
  }
</style>
